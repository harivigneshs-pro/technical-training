#include<iostream>
using namespace std;
void print(int n)
{
    if(n==0)
    return;
    cout<<n<<endl;
    print(n-1);
        
}
void printfor(int n)
{
    if(n==0)
    return;
    else
    {
        print(n-1);
        cout<<n<<endl;
    }
}
int main()
{
    int n=5;
    print(5);
    printfor(5);
}